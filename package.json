{
  "name": "tadori",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "ML メール検索ツール — SharePoint 上で動くクライアントサイドベクトル検索 (bookmarklet)",
  "scripts": {
    "dev": "node build.js --watch --serve",
