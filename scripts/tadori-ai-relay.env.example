# ============================================================================
# Tadori AI relay — 設定ファイル
# ============================================================================
#
# このファイルをコピーして `tadori-ai-relay.env` として保存し、自分の環境に
# 合わせて値を編集してください。
#
#   PowerShell:   Copy-Item tadori-ai-relay.env.example tadori-ai-relay.env
#   コマンド:     copy tadori-ai-relay.env.example tadori-ai-relay.env
#
# `tadori-ai-relay.env` は .gitignore で除外され、リポジトリにはコミット
# されません (秘密情報を安全に入れられます)。
#
# 形式: 1 行 1 設定、KEY=VALUE。コメントは `#` から行末まで。
# クォート (`"..."` / `'...'`) があれば自動で剥がします。
# ============================================================================

# 社内 AI ゲートウェイ / Azure OpenAI 互換エンドポイントの URL (パスまで含む)
# 例: Azure OpenAI リソースのベース
TADORI_AI_TARGET=https://YOUR-RESOURCE.openai.azure.com

# オンプレ プロキシの URL (不要なら空 or 行ごと削除)
TADORI_AI_PROXY=http://onprem-proxy.example.com:8080

# ローカル listen ポート (Tadori 側「ベース URL」と同期させる)
TADORI_AI_PORT=18080

# 任意: 自己署名証明書を許容 (検証用途のみ、本番禁止)。値を `1` で有効。
# TADORI_AI_SKIP_CERT_CHECK=0

# ─── ワンクリック起動 (tadori-start.bat) で使う設定 ───────────────────────
# tadori-start.bat / tadori-start.ps1 が「リレー起動 + ブラウザで SharePoint
# を開く + 案内ダイアログ表示」を 1 アクションでやってくれる。
#
# このアプリ自体は SharePoint のどのサイトからでも起動できる (ブックマーク
# レット形式)。なので TADORI_SITE_URL は「あなたがいつも開く Tadori の置き場」
# = チームで共有してる SP サイトの URL を 1 つ書いておけば OK。
#
# 運用パターン:
#   - チーム共通: env を git で共有していれば、全員が同じ SP サイトに飛ぶ
#   - 個人別: 各自の env に自分用 URL を書けば自分の場所が開く
#   - 未設定: 起動時にプロンプトで URL を聞かれる (1 回入力すれば次回から覚える
#            よう env に書き込んでおく)
#
# 取得方法: SharePoint でいつも Tadori を起動してるサイトのトップ URL をコピー。
#   例: https://contoso.sharepoint.com/sites/team-tadori
#       https://contoso.sharepoint.com/sites/foo/SitePages/Home.aspx
#       (サブパスでも OK。SharePoint ページなら何でも)
#
# TADORI_SITE_URL=https://<tenant>.sharepoint.com/sites/<site>
